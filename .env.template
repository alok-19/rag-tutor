# Choose LLM provider: gemini | openai | deepseek
# For hybrid setups (e.g. DeepSeek chat + OpenAI embeddings), also set EMBEDDING_PROVIDER
LLM_PROVIDER=gemini
# EMBEDDING_PROVIDER=openai

# --- Gemini (Google) ---
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# GEMINI_PRIMARY_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# --- OpenAI ---
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_PRIMARY_MODEL=gpt-4o-mini
# OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# --- DeepSeek (OpenAI-compatible) ---
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_PRIMARY_MODEL=deepseek-v4-flash
# DEEPSEEK_FALLBACK_MODEL=deepseek-v4-pro

# Optional: directories
CHROMA_DB_PATH=chroma_db
STUDY_MATERIALS_DIR=study_materials