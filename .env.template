# Choose LLM provider: gemini | openai | deepseek
# For hybrid setups (e.g. DeepSeek chat + OpenAI embeddings), also set EMBEDDING_PROVIDER
LLM_PROVIDER=gemini
# EMBEDDING_PROVIDER=openai

# --- Gemini (Google) ---
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# GEMINI_PRIMARY_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-1.5-flash

# --- OpenAI ---
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_PRIMARY_MODEL=gpt-4o-mini
# OPENAI_FALLBACK_MODEL=gpt-3.5-turbo

# --- DeepSeek (OpenAI-compatible) ---
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_PRIMARY_MODEL=deepseek-v4-flash
# DEEPSEEK_FALLBACK_MODEL=deepseek-v4-pro

# --- BGE-M3 (local embeddings, requires `[hybrid]` extras) ---
# Set EMBEDDING_PROVIDER=bge to use the local BGE-M3 model for embeddings.
# No API key needed. The model downloads on first use (~2.3 GB).
# BGE_M3_MODEL_NAME=BAAI/bge-m3
# BGE_M3_DIM=1024
# BGE_M3_DEVICE=cpu

# --- BGE Reranker (two-stage retrieval, requires `[hybrid]` extras) ---
# Set ENABLE_RERANKER=true to fetch N candidates then rerank with a
# cross-encoder. Off by default to avoid the ~1-2 GB model download.
# ENABLE_RERANKER=false
# RERANKER_MODEL=BAAI/bge-reranker-base
# RERANKER_INITIAL_K=20

# --- Chunking strategy ---
# "recursive" (default, langchain) | "llama_index" (LlamaIndex SentenceSplitter
# with hash-based dedup; requires `[hybrid]` extras)
# CHUNKING_STRATEGY=recursive

# Optional: directories
CHROMA_DB_PATH=chroma_db
STUDY_MATERIALS_DIR=study_materials